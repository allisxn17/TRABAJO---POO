import random

class Semilla:
    def __init__(self, x, y, tiempo_crecimiento):
       self.x = x
       self.y = y
       self.tiempo_crecimiento = tiempo_crecimiento

    def crecer(self):
        if self.tiempo_crecimiento > 0:
            self.tiempo_crecimiento -= 1
            print("La semilla esta creciendo...")
            print("Tiempo restante:", self.tiempo_crecimiento)

    def germinar(self):
        if self.tiempo_crecimiento <= 0:
            print("La semilla germino y se convirtio en planta")
            return True
        return False

class Refugio:
    def __init__(self, x, y, capacidad):
        self.x = x
        self.y = y
        self.capacidad = capacidad

    def proteger(self, insecto):
        if insecto["posicion"] == (self.x, self.y):
            print("El refugio está protegiendo al insecto")

        else:
            print("El insecto no está en la posición del refugio")

    def recuperar_energia(self, insecto):
        if insecto["posicion"] == (self.x, self.y):

            energia_recuperada = random.randint(1, 3)

            insecto["energia"] += energia_recuperada

            print("Energía recuperada:", energia_recuperada)

            print("Energía actual:", insecto["energia"])

        else:
            print("El insecto no está en el refugio")


def simulacion():

    # creación de objetos con valores aleatorios
    semilla = Semilla(
        random.randint(0, 5),
        random.randint(0, 5),
        random.randint(3, 5)
    )

    refugio = Refugio(
        random.randint(0, 5),
        random.randint(0, 5),
        2
    )

    insecto = {
        "posicion": (
            random.randint(0, 5),
            random.randint(0, 5)
        ),
        "energia": random.randint(5, 8)
    }

    ciclo = 1

    print("Posición inicial de la semilla:", semilla.x, semilla.y)
    print("Tiempo inicial de crecimiento:", semilla.tiempo_crecimiento)

    print("Posición del refugio:", refugio.x, refugio.y)
    print("Capacidad del refugio:", refugio.capacidad)

    print("Posición del insecto:", insecto["posicion"])
    print("Energía inicial del insecto:", insecto["energia"])

    print("\n--- Iniciando simulación ---")

    while True:

        print("\nCiclo", ciclo)

        print("\nOpciones:")
        print("1. Avanzar ciclo")
        print("2. Usar refugio")
        print("3. Mostrar estado")
        print("4. Salir")

        opcion = input("Seleccione una opción: ")

        if opcion == "1":

            semilla.crecer()

            if semilla.germinar():

                print("Fin de la simulación")

                break

            ciclo += 1

        elif opcion == "2":

            refugio.proteger(insecto)

            refugio.recuperar_energia(insecto)

        elif opcion == "3":

            print("\nEstado actual:")
            print("Tiempo restante:", semilla.tiempo_crecimiento)
            print("Energía del insecto:", insecto["energia"])

        elif opcion == "4":

            print("Simulación finalizada")

            break

        else:

            print("Opción inválida")


simulacion()







